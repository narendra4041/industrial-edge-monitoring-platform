# Application
APP_NAME="Industrial Edge Monitoring Platform API"
APP_ENV="local"
API_V1_PREFIX="/api/v1"
LOG_LEVEL="INFO"

# Database
DATABASE_URL="postgresql+psycopg://edge_user:edge_password@localhost:5432/industrial_edge"

# Security
JWT_SECRET_KEY="change-me-for-local-development"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Device authentication
DEVICE_API_KEY_HEADER="X-Device-Api-Key"

# Observability
ENABLE_METRICS=true
ENABLE_TRACING=false